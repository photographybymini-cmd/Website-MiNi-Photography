---
import '../styles/gallery.css';

const angebote = [
  {
    image: '/images/angebote/Hochzeiten-Angebot.jpg',
    alt: 'Hochzeitsfotografie – MiNi Fotografie',
    label: 'Hochzeiten',
    tagline: 'Euer schönster Tag, für immer festgehalten.',
    href: '/hochzeiten',
  },
  {
    image: '/images/angebote/Paare-Angebot.jpg',
    alt: 'Paarfotografie – MiNi Fotografie',
    label: 'Paare',
    tagline: 'Eure Liebe, natürlich und ungestellt.',
    href: '/paare',
  },
  {
    image: '/images/angebote/Familien-Angebot.jpg',
    alt: 'Familienfotografie – MiNi Fotografie',
    label: 'Familien',
    tagline: 'Momente, die eure Familie zusammenhält.',
    href: '/familie',
  },
];
---

<section class="angebote" id="galerie" aria-labelledby="angebote-heading">
  <div class="container">

    <header class="angebote__header reveal">
      <span class="section-label">Was wir anbieten</span>
      <h2 id="angebote-heading" class="angebote__heading">
        Fotografie, die bewegt.
      </h2>
    </header>

    <div class="angebote__grid">
      {angebote.map((item, i) => (
        <div class={`angebote__card reveal${i > 0 ? ` reveal--delay-${i}` : ''}`}>
          <div class="angebote__card-image">
            <img
              src={item.image}
              alt={item.alt}
              width="800"
              height="1100"
              loading="lazy"
            />
            <div class="angebote__card-overlay">
              <span class="angebote__card-label">{item.label}</span>
              <p class="angebote__card-tagline">{item.tagline}</p>
            </div>
          </div>
          <a href={item.href} class="angebote__card-btn">
            Mehr erfahren
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="3" y1="8" x2="13" y2="8"/>
              <polyline points="9,4 13,8 9,12"/>
            </svg>
          </a>
        </div>
      ))}
    </div>

  </div>
</section>
