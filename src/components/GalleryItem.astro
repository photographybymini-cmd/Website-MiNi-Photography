---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  index: number;
}

const { src, alt, caption = '', index } = Astro.props;
---
<figure
  class="gallery-item"
  role="button"
  tabindex="0"
  aria-label={`Bild vergrößern: ${alt}`}
  data-lightbox-index={index}
  data-lightbox-src={src}
  data-lightbox-caption={caption}
>
  <img
    class="gallery-item__image"
    src={src}
    alt={alt}
    loading="lazy"
    decoding="async"
  />
  {caption && (
    <figcaption class="gallery-item__caption">{caption}</figcaption>
  )}
  <div class="gallery-item__icon" aria-hidden="true">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <polyline points="9,1 13,1 13,5"/>
      <polyline points="5,13 1,13 1,9"/>
      <line x1="13" y1="1" x2="8" y2="6"/>
      <line x1="1" y1="13" x2="6" y2="8"/>
    </svg>
  </div>
</figure>
