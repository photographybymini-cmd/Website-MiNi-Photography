---
import '../styles/footer.css';
const year = new Date().getFullYear();
---
<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__inner">
      <p class="footer__copy">
        &copy; {year} MiNi Photography &middot; Miette &amp; Nicolai &middot; Alle Rechte vorbehalten
      </p>
      <a href="#" class="footer__top" aria-label="Zurück nach oben">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="8" y1="13" x2="8" y2="3"/>
          <polyline points="4,7 8,3 12,7"/>
        </svg>
        <span>Nach oben</span>
      </a>
    </div>
    <div class="footer__legal">
      <a href="/impressum" class="footer__legal-link">Impressum</a>
      <span class="footer__legal-dot" aria-hidden="true">&middot;</span>
      <a href="/datenschutz" class="footer__legal-link">Datenschutz</a>
    </div>
  </div>
</footer>
