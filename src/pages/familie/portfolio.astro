---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/portfolio.css';

const photos = [
  { src: '/images/familie/erinnerungen-die-bleiben.jpg', alt: 'Familienshooting – Erinnerungen die bleiben', tall: true },
  { src: '/images/familie/gemeinsam-zeit-verbringen.jpg', alt: 'Familienshooting – Gemeinsame Zeit'                    },
  { src: '/images/familie/wachstum-veraenderung.jpg',    alt: 'Familienshooting – Wachstum & Veränderung'              },
  { src: '/images/gallery/06.jpg',                       alt: 'Familienshooting – Glücklicher Moment',    wide: true  },
  { src: '/images/gallery/08.jpg',                       alt: 'Familienshooting – Echte Freude'                       },
  { src: '/images/gallery/10.jpg',                       alt: 'Familienshooting – Familienbande',         tall: true  },
  { src: '/images/gallery/12.jpg',                       alt: 'Familienshooting – Natürliche Nähe'                    },
  { src: '/images/gallery/04.jpg',                       alt: 'Familienshooting – Stimmungsvoller Abend'              },
  { src: '/images/gallery/02.jpg',                       alt: 'Familienshooting – Lachen & Leichtigkeit', wide: true  },
  { src: '/images/gallery/07.jpg',                       alt: 'Familienshooting – Geborgenheit'                       },
  { src: '/images/gallery/09.jpg',                       alt: 'Familienshooting – Kostbare Momente'                   },
];
---

<BaseLayout
  title="Familien Portfolio – MiNi Photography"
  description="Authentische Familienfotografie – unser Portfolio der schönsten Familienmomente. Natürlich und lebendig eingefangen von Miette & Nicolai."
>
  <Nav />
  <main id="main">

    <!-- Hero -->
    <section class="pf-hero" aria-label="Portfolio Familien">
      <div class="pf-hero__inner">
        <a href="/familie" class="pf-hero__back">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="13" y1="8" x2="3" y2="8"/><polyline points="7,4 3,8 7,12"/>
          </svg>
          Familienfotografie
        </a>
        <span class="pf-hero__label">Portfolio</span>
        <h1 class="pf-hero__title"><em>Familien.</em></h1>
        <p class="pf-hero__count">{photos.length} Aufnahmen</p>
      </div>
    </section>

    <!-- Intro -->
    <div class="pf-intro">
      <div class="pf-intro__inner">
        <div class="pf-intro__text">
          <h2 class="pf-intro__heading">Momente, die für immer<br/>zu eurer Geschichte gehören.</h2>
          <p class="pf-intro__sub">Kinder wachsen schnell – wir halten fest, was bleibt: die Wärme, das Lachen, das Miteinander.</p>
        </div>
        <a href="/familie" class="pf-intro__link">
          Mehr über Familienfotografie
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="3" y1="8" x2="13" y2="8"/><polyline points="9,4 13,8 9,12"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Grid -->
    <section class="pf-grid-section">
      <div class="pf-grid-section__inner">
        <div class="pf-grid">
          {photos.map((p) => (
            <div class={`pf-item${p.tall ? ' pf-item--tall' : ''}${p.wide ? ' pf-item--wide' : ''}`}>
              <img src={p.src} alt={p.alt} loading="lazy" />
              <div class="pf-item__overlay"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="pf-cta">
      <div class="pf-cta__inner">
        <span class="pf-cta__label">Für eure Familie</span>
        <h2 class="pf-cta__heading">Euer nächstes <em>Familienshooting?</em></h2>
        <div class="pf-cta__btns">
          <a href="/#kontakt" class="pf-cta__btn pf-cta__btn--primary">
            Jetzt anfragen
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="3" y1="8" x2="13" y2="8"/><polyline points="9,4 13,8 9,12"/>
            </svg>
          </a>
          <a href="/preise" class="pf-cta__btn pf-cta__btn--secondary">Preise & Pakete</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
