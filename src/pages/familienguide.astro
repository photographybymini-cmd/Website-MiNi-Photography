---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Familien Guide – MiNi Photography"
  description="Babybauch, Newborn & Familienfotografie aus Frankfurt und Umgebung – Pakete, Tipps und Ablauf eures Shootings mit Miette & Nicolai."
  image="/images/familienguide/hero.jpg"
>
  <!-- NAV -->
  <nav class="fg-nav">
    <div class="fg-nav-logo">MiNi Photography</div>
    <ul class="fg-nav-links">
      <li><a href="#shootings">Shootings</a></li>
      <li><a href="#pakete">Pakete</a></li>
      <li><a href="#tipps">Tipps</a></li>
      <li><a href="#ablauf">Ablauf</a></li>
      <li><a href="#kontakt">Kontakt</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="fg-hero">
    <div class="fg-hero-left">
      <span class="fg-hero-tag">Familien Guide · MiNi Photography</span>
      <h1 class="fg-hero-title">Momente, die<br><em>für immer</em><br>bleiben.</h1>
      <p class="fg-hero-subtitle">Babybauch · Newborn · Familie<br>Frankfurt &amp; Umgebung</p>
      <a href="#kontakt" class="fg-hero-cta">Jetzt anfragen</a>
      <div class="fg-hero-scroll">
        <div class="fg-scroll-line"></div>
        <span>Entdecken</span>
      </div>
    </div>
    <div class="fg-hero-right">
      <img src="/images/familienguide/hero.jpg" alt="Miette & Nicolai" />
    </div>
  </section>

  <!-- ABOUT -->
  <section class="fg-about" id="about">
    <div class="fg-container">
      <div class="fg-about-grid">
        <div class="fg-about-img reveal">
          <img src="/images/familienguide/about.jpg" alt="Miette & Nicolai – MiNi Photography" />
          <div class="fg-about-badge">Euer Glück ist unser Glück</div>
        </div>
        <div class="fg-about-text reveal">
          <span class="fg-section-label">Wer wir sind</span>
          <h2 class="fg-section-title">Hallo, wir sind <em>Miette &amp; Nicolai!</em></h2>
          <div class="fg-divider"></div>
          <p>Wir sind ein eingespieltes Fotografen-Duo aus der Region Frankfurt – leidenschaftlich, herzlich und immer auf der Suche nach dem echten Moment.</p>
          <p>Als junges Paar wissen wir selbst, wie kostbar diese besonderen Lebensphasen sind – der runde Bauch, die ersten Tage mit dem Neugeborenen, das Lachen einer Familie. Genau das wollen wir für euch festhalten: authentisch, ungestellt und voller Gefühl.</p>
          <p>Da wir zu zweit sind, entstehen gleichzeitig Aufnahmen aus verschiedenen Blickwinkeln – für eine vielseitige und stimmige Bildgeschichte.</p>
          <div class="fg-about-signature">Miette &amp; Nicolai</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SHOOTING CATEGORIES -->
  <section class="fg-categories" id="shootings">
    <div class="fg-container">
      <div class="fg-categories-header reveal">
        <span class="fg-section-label">Unsere Leistungen</span>
        <h2 class="fg-section-title">Was wir für euch <em>festhalten</em></h2>
        <div class="fg-divider"></div>
      </div>
      <div class="fg-cat-grid">
        <div class="fg-cat-card reveal">
          <div class="fg-cat-card-inner" style="background: #d4c4b5;">
            <img src="/images/familienguide/babybauch.jpg" alt="Babybauch Shooting" class="fg-cat-img" />
            <div class="fg-cat-number">01</div>
            <div class="fg-cat-content">
              <div class="fg-cat-title">Babybauch</div>
              <div class="fg-cat-subtitle">Schwangerschaft · Vorfreude</div>
              <div class="fg-cat-desc">Die Schwangerschaft ist eine der schönsten Phasen im Leben – voller Vorfreude und tiefer Verbundenheit. Wir halten diese besondere Zeit in stimmungsvollen, natürlichen Bildern fest.</div>
              <div class="fg-cat-tip">✨ Ideal zwischen der 28. und 34. Schwangerschaftswoche</div>
            </div>
          </div>
        </div>
        <div class="fg-cat-card reveal" style="transition-delay: 0.15s">
          <div class="fg-cat-card-inner" style="background: #c4b4a5;">
            <img src="/images/familienguide/newborn.jpg" alt="Newborn Shooting" class="fg-cat-img fg-cat-img--top" />
            <div class="fg-cat-number">02</div>
            <div class="fg-cat-content">
              <div class="fg-cat-title">Newborn</div>
              <div class="fg-cat-subtitle">Neugeborene · Erste Momente</div>
              <div class="fg-cat-desc">Die ersten Wochen mit eurem Baby – so zart, so wunderbar. Wir gehen behutsam vor, nehmen uns Zeit und schaffen eine ruhige Atmosphäre, in der sich alle wohlfühlen.</div>
              <div class="fg-cat-tip">✨ In den ersten 2–3 Wochen nach der Geburt</div>
            </div>
          </div>
        </div>
        <div class="fg-cat-card reveal" style="transition-delay: 0.3s">
          <div class="fg-cat-card-inner" style="background: #b4a495;">
            <img src="/images/familienguide/familie.jpg" alt="Familien Shooting" class="fg-cat-img fg-cat-img--top" />
            <div class="fg-cat-number">03</div>
            <div class="fg-cat-content">
              <div class="fg-cat-title">Familie</div>
              <div class="fg-cat-subtitle">Familien · Geschwister · Haustiere</div>
              <div class="fg-cat-desc">Das Lachen, die Umarmungen, die kleinen Details – wir holen das Beste aus euch heraus. Keine steifen Posen, sondern lebendige Aufnahmen die eure Familie wirklich zeigen.</div>
              <div class="fg-cat-tip">✨ Goldene Stunde: kurz vor Sonnenuntergang</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PACKAGES -->
  <section class="fg-packages" id="pakete">
    <div class="fg-container">
      <div class="fg-packages-header reveal">
        <span class="fg-section-label">Investition</span>
        <h2 class="fg-section-title">Unsere <em>Pakete</em></h2>
        <div class="fg-divider" style="margin: 0 auto 2rem;"></div>
      </div>
      <div class="fg-pkg-grid">
        <div class="fg-pkg-card reveal">
          <div class="fg-pkg-name">Basic</div>
          <div class="fg-pkg-price"><span>€</span>100</div>
          <div class="fg-pkg-divider"></div>
          <ul class="fg-pkg-features">
            <li>bis zu 20 Minuten Shooting mit 2 Fotografen</li>
            <li>10 bearbeitete Fotos (jedes weitere 4 €)</li>
            <li>Onlinegalerie zum Download</li>
            <li>Anfahrt 35 ct/km</li>
            <li>Bearbeitungszeit bis zu 7 Tage</li>
          </ul>
        </div>
        <div class="fg-pkg-card fg-featured reveal" style="transition-delay: 0.15s">
          <div class="fg-pkg-name">Classic</div>
          <div class="fg-pkg-price"><span>€</span>150</div>
          <div class="fg-pkg-divider"></div>
          <ul class="fg-pkg-features">
            <li>bis zu 1 Stunde Shooting mit 2 Fotografen</li>
            <li>Mind. 30 bearbeitete Fotos</li>
            <li>Onlinegalerie zum Download</li>
            <li>Anfahrt 30 km inklusive, dann 35 ct/km</li>
            <li>Bearbeitungszeit bis zu 7 Tage</li>
            <li class="fg-pkg-feature-accent">3× mehr Zeit als Basic</li>
          </ul>
        </div>
        <div class="fg-pkg-card reveal" style="transition-delay: 0.3s">
          <div class="fg-pkg-name">Premium</div>
          <div class="fg-pkg-price"><span>€</span>200</div>
          <div class="fg-pkg-divider"></div>
          <ul class="fg-pkg-features">
            <li>bis zu 2 Stunden Shooting mit 2 Fotografen</li>
            <li>Mind. 50 bearbeitete Fotos</li>
            <li>Onlinegalerie zum Download</li>
            <li>Anfahrt 50 km inklusive, dann 35 ct/km</li>
            <li>Bearbeitungszeit bis zu 10 Tage</li>
            <li class="fg-pkg-feature-accent">Größte Auswahl &amp; meiste Zeit</li>
          </ul>
        </div>
      </div>
      <div class="fg-extras-bar reveal">
        <div class="fg-extra-item">
          <div>
            <div class="fg-extra-label">🎬 Highlightvideo</div>
            <div class="fg-extra-desc">ca. 2–5 Minuten · Preis auf Anfrage</div>
          </div>
          <div class="fg-extra-price-tag fg-extra-price-tag--light">auf Anfrage</div>
        </div>
        <div class="fg-extras-divider"></div>
        <div class="fg-extra-item">
          <div>
            <div class="fg-extra-label">🚁 Drohnenaufnahmen</div>
            <div class="fg-extra-desc">Einzigartige Perspektive aus der Vogelperspektive</div>
          </div>
          <div class="fg-extra-price-tag fg-extra-price-tag--light">20 €</div>
        </div>
      </div>
    </div>
  </section>

  <!-- TIPS -->
  <section class="fg-tips" id="tipps">
    <div class="fg-container">
      <div class="fg-tips-header reveal">
        <span class="fg-section-label">Vorbereitung</span>
        <h2 class="fg-section-title">Unsere <em>Tipps</em> für euch</h2>
        <div class="fg-divider"></div>
      </div>
      <div class="fg-tips-grid">
        <div class="fg-tip-card reveal">
          <span class="fg-tip-icon">👗</span>
          <div class="fg-tip-title">Outfit &amp; Farben</div>
          <p class="fg-tip-text">Wählt aufeinander abgestimmte, gedeckte Farbtöne – Beige, Weiß, Erdtöne oder sanfte Blautöne wirken besonders harmonisch. Vermeidet große auffällige Muster oder Logo-Prints, die vom Wesentlichen ablenken.</p>
          <div class="fg-tip-highlight">→ Tipp: Mehrere Layers (z.B. Jacke/Cardigan) geben euch mehr Abwechslung</div>
        </div>
        <div class="fg-tip-card reveal" style="transition-delay: 0.1s">
          <span class="fg-tip-icon">🌅</span>
          <div class="fg-tip-title">Das Licht macht den Unterschied</div>
          <p class="fg-tip-text">Die schönsten Bilder entstehen in der „Goldenen Stunde" – ca. 1 Stunde vor Sonnenuntergang. Das warme, weiche Licht schmeichelt und schafft eine magische Atmosphäre. Wir helfen euch gerne bei der Zeitplanung!</p>
          <div class="fg-tip-highlight">→ Für Newborn: Natürliches Tageslicht am Vormittag ist ideal</div>
        </div>
        <div class="fg-tip-card reveal" style="transition-delay: 0.2s">
          <span class="fg-tip-icon">📍</span>
          <div class="fg-tip-title">Die richtige Location</div>
          <p class="fg-tip-text">Orte mit persönlicher Bedeutung machen Bilder besonders. Parks, Wälder, Felder oder eure eigene Wohnung – alles ist möglich. In Frankfurt und Umgebung gibt es viele wunderschöne Spots. Wir kennen einige Geheimtipps!</p>
          <div class="fg-tip-highlight">→ Gerne beraten wir euch persönlich zu Locations</div>
        </div>
        <div class="fg-tip-card reveal" style="transition-delay: 0.3s">
          <span class="fg-tip-icon">😊</span>
          <div class="fg-tip-title">Entspannt bleiben</div>
          <p class="fg-tip-text">Das Wichtigste: Entspannt euch und habt Spaß! Kinder dürfen Kinder sein, Babys dürfen quengeln – wir nehmen uns die Zeit die wir brauchen. Die echten Momente entstehen wenn niemand ans Fotografiert-werden denkt.</p>
          <div class="fg-tip-highlight">→ Bringt eure Lieblingssnacks mit – gute Stimmung garantiert!</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="fg-process" id="ablauf">
    <div class="fg-container">
      <div class="fg-process-header reveal">
        <span class="fg-section-label">Wie es läuft</span>
        <h2 class="fg-section-title">Von der Anfrage zu<br><em>euren Bildern</em></h2>
        <div class="fg-divider" style="margin: 0 auto 2rem;"></div>
      </div>
      <div class="fg-process-steps">
        <div class="fg-step reveal">
          <div class="fg-step-num">01</div>
          <div class="fg-step-title">Anfrage</div>
          <p class="fg-step-text">Schreibt uns eine kurze Nachricht – per WhatsApp, Instagram oder E-Mail. Wir melden uns schnell zurück!</p>
        </div>
        <div class="fg-step reveal" style="transition-delay: 0.15s">
          <div class="fg-step-num">02</div>
          <div class="fg-step-title">Gespräch</div>
          <p class="fg-step-text">Wir klären eure Wünsche, besprechen Location, Datum und Uhrzeit – persönlich oder per Telefon.</p>
        </div>
        <div class="fg-step reveal" style="transition-delay: 0.3s">
          <div class="fg-step-num">03</div>
          <div class="fg-step-title">Shooting</div>
          <p class="fg-step-text">Wir kommen zu euch, entspannen gemeinsam und halten eure Momente auf natürliche Weise fest.</p>
        </div>
        <div class="fg-step reveal" style="transition-delay: 0.45s">
          <div class="fg-step-num">04</div>
          <div class="fg-step-title">Bilder</div>
          <p class="fg-step-text">Ihr erhaltet eure fertig bearbeiteten Bilder in einer persönlichen Onlinegalerie zum Download.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="fg-reviews">
    <div class="fg-container">
      <div class="fg-reviews-header reveal">
        <span class="fg-section-label">Kundenstimmen</span>
        <h2 class="fg-section-title">Was unsere Kunden <em>sagen</em></h2>
        <div class="fg-divider" style="margin: 0 auto 2rem;"></div>
      </div>
      <div class="fg-reviews-grid">
        <div class="fg-review-card reveal">
          <div class="fg-review-badge">★ 5</div>
          <span class="fg-review-quote">"</span>
          <div class="fg-review-stars">★★★★★</div>
          <p class="fg-review-text">Wir sind sehr sehr zufrieden mit den beiden Fotografen, wir haben bereits 3 Shootings gemeinsam gehabt und haben Miette und Nicolai als sehr freundlich und herzliche Menschen kennengelernt. Die entstandenen Bilder sind sehr schön geworden, sie sind sehr natürlich, man hat zu keinem Zeitpunkt das Gefühl, das etwas „gestellt" ist. Zudem ist die Bearbeitung der Fotos super schnell. Wir freuen uns jetzt schon auf unser nächstes Shooting mit den Beiden.</p>
          <div class="fg-review-author">Mike Ziegler</div>
        </div>
        <div class="fg-review-card reveal" style="transition-delay: 0.2s">
          <div class="fg-review-badge">★ 5</div>
          <span class="fg-review-quote">"</span>
          <div class="fg-review-stars">★★★★★</div>
          <p class="fg-review-text">Das Fotoshooting mit den beiden hat wirklich sehr viel Spaß gemacht. Das schöne dabei war auch das sie für alle Wünsche offen sind und das wirklich mit Herzblut zusammen machen. Kann ich wirklich nur empfehlen.</p>
          <div class="fg-review-author">Philipp</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="fg-faq">
    <div class="fg-container">
      <div class="fg-faq-grid">
        <div class="fg-faq-left reveal">
          <span class="fg-section-label">Häufige Fragen</span>
          <h2 class="fg-section-title">Ihr habt <em>Fragen?</em><br>Wir haben Antworten.</h2>
          <div class="fg-divider"></div>
          <p>Noch etwas unklar? Schreibt uns einfach – wir antworten schnell und freuen uns über jede Nachricht!</p>
        </div>
        <div class="fg-faq-items reveal" style="transition-delay: 0.2s">
          <div class="fg-faq-item">
            <div class="fg-faq-q">Wie werden die Bilder bearbeitet?</div>
            <div class="fg-faq-a">Wir nutzen Adobe Lightroom und bei Bedarf Photoshop. Dabei achten wir besonders auf ein natürliches Bild und einen einheitlichen Look. Mit Retusche gehen wir sparsam um, entfernen aber kleine störende Details. Auf Wunsch bieten wir zusätzlich schwarz-weiß Bilder an.</div>
          </div>
          <div class="fg-faq-item">
            <div class="fg-faq-q">Was, wenn das Baby weint oder die Kinder nicht mitmachen?</div>
            <div class="fg-faq-a">Das ist völlig normal und kein Problem! Wir nehmen uns die Zeit die wir brauchen, machen Pausen und warten ab. Oft entstehen gerade in solchen Momenten die ehrlichsten und schönsten Bilder. Kein Stress – wir haben Erfahrung darin, auch mit kleinen Quengelkindern tolle Fotos zu machen.</div>
          </div>
          <div class="fg-faq-item">
            <div class="fg-faq-q">Was ist, wenn es regnet?</div>
            <div class="fg-faq-a">Für den Fall, dass es regnet, haben wir einen durchsichtigen Regenschirm für euch parat. Regen kann wunderschöne, stimmungsvolle Fotos ergeben – und unsere Kameras sind spritzwassergeschützt! Bei starkem Regen können wir auch kurzfristig verschieben.</div>
          </div>
          <div class="fg-faq-item">
            <div class="fg-faq-q">Wie und wann bezahlen wir?</div>
            <div class="fg-faq-a">Bei uns könnt ihr per PayPal, Überweisung oder bei kleineren Beträgen in Bar zahlen. Eine Anzahlung von 20 % wird bei Terminreservierung fällig – der Rest, bevor ihr die Bilder erhaltet.</div>
          </div>
          <div class="fg-faq-item">
            <div class="fg-faq-q">Wie werden die Bilder gesichert?</div>
            <div class="fg-faq-a">Eure Bilder werden auf zuverlässigen Speichermedien gesichert und als Backup auf mehreren Datenträgern aufbewahrt. Beim Shooting selbst sichern wir die Bilder auf zwei Speicherkarten gleichzeitig.</div>
          </div>
          <div class="fg-faq-item">
            <div class="fg-faq-q">Wann ist der beste Zeitpunkt für ein Babybauch-Shooting?</div>
            <div class="fg-faq-a">Ideal ist die Zeit zwischen der 28. und 34. Schwangerschaftswoche. Der Bauch ist schön rund und ihr fühlt euch noch rundum wohl. Für Newborn-Shootings empfehlen wir die ersten 2–3 Wochen nach der Geburt.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="fg-contact" id="kontakt">
    <div class="fg-container">
      <span class="fg-section-label fg-text-center">Bereit?</span>
      <h2 class="fg-section-title">Lasst uns eure<br><em>Geschichte</em> erzählen.</h2>
      <p class="fg-contact-sub">Wir freuen uns auf eure Nachricht!</p>
      <div class="fg-contact-links">
        <a href="https://wa.me/4917675871418" class="fg-contact-link">
          <div class="fg-contact-link-icon">📱</div>
          +49 176 75871418
        </a>
        <a href="mailto:info@mini-foto.de" class="fg-contact-link">
          <div class="fg-contact-link-icon">✉️</div>
          info@mini-foto.de
        </a>
        <a href="https://www.mini-foto.de" class="fg-contact-link" target="_blank" rel="noopener">
          <div class="fg-contact-link-icon">🌐</div>
          www.mini-foto.de
        </a>
        <a href="https://www.instagram.com/photography.by.mini" class="fg-contact-link" target="_blank" rel="noopener">
          <div class="fg-contact-link-icon">📷</div>
          @photography.by.mini
        </a>
      </div>
      <a href="https://wa.me/4917675871418" class="fg-cta-btn">Jetzt anfragen</a>
      <div class="fg-contact-signature">Miette &amp; Nicolai</div>
      <p class="fg-copyright">angegebene Preise haben keine Bindung &nbsp;·&nbsp; COPYRIGHT © 2024 MINI PHOTOGRAPHY</p>
    </div>
  </section>

  <!-- BACK TO TOP -->
  <button id="fgBackToTop" class="fg-back-to-top" aria-label="Nach oben">↑</button>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Jost:wght@300;400;500&display=swap');

    /* === Familienguide page (scoped via fg- prefix) === */
    body:has(.fg-hero) {
      font-family: 'Jost', sans-serif;
      background: #FFFCFA;
      color: #3d3532;
      overflow-x: hidden;
    }

    .fg-hero, .fg-hero *,
    .fg-about, .fg-about *,
    .fg-categories, .fg-categories *,
    .fg-packages, .fg-packages *,
    .fg-tips, .fg-tips *,
    .fg-process, .fg-process *,
    .fg-reviews, .fg-reviews *,
    .fg-faq, .fg-faq *,
    .fg-contact, .fg-contact *,
    .fg-nav, .fg-nav *,
    .fg-back-to-top {
      box-sizing: border-box;
    }

    /* NAV */
    .fg-nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 1.2rem 2.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(255,252,250,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(145,124,113,0.15);
      transition: all 0.3s ease;
    }
    .fg-nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      color: #7A6560;
      letter-spacing: 0.05em;
    }
    .fg-nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .fg-nav-links a {
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #888;
      text-decoration: none;
      transition: color 0.2s;
    }
    .fg-nav-links a:hover,
    .fg-nav-links a.active { color: #C17F3A; }

    /* HERO */
    .fg-hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      position: relative;
      overflow: hidden;
    }
    .fg-hero-left {
      background: #3d3532;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 8rem 5rem 5rem 5rem;
      position: relative;
      overflow: hidden;
    }
    .fg-hero-left::before {
      content: '';
      position: absolute;
      top: -50%; right: -30%;
      width: 80%;
      height: 200%;
      background: radial-gradient(ellipse, rgba(193,127,58,0.12) 0%, transparent 70%);
    }
    .fg-hero-tag {
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #C17F3A;
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fgFadeUp 0.8s 0.2s forwards;
    }
    .fg-hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3rem, 5vw, 4.5rem);
      line-height: 1.1;
      color: #fff;
      margin: 0 0 1.5rem;
      opacity: 0;
      animation: fgFadeUp 0.8s 0.4s forwards;
    }
    .fg-hero-title em {
      font-style: italic;
      color: #d4975a;
    }
    .fg-hero-subtitle {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem;
      font-style: italic;
      color: rgba(255,255,255,0.55);
      line-height: 1.7;
      max-width: 380px;
      margin: 0 0 3rem;
      opacity: 0;
      animation: fgFadeUp 0.8s 0.6s forwards;
    }
    .fg-hero-cta {
      display: inline-block;
      padding: 1rem 2.5rem;
      background: transparent;
      border: 1px solid #C17F3A;
      color: #C17F3A;
      font-family: 'Jost', sans-serif;
      font-size: 0.78rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      text-decoration: none;
      transition: all 0.3s ease;
      opacity: 0;
      animation: fgFadeUp 0.8s 0.8s forwards;
      width: fit-content;
    }
    .fg-hero-cta:hover {
      background: #C17F3A;
      color: #fff;
    }
    .fg-hero-right {
      position: relative;
      overflow: hidden;
    }
    .fg-hero-right img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      filter: saturate(0.85);
      display: block;
    }
    .fg-hero-right::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, rgba(61,53,50,0.4) 0%, transparent 40%);
    }
    .fg-hero-scroll {
      position: absolute;
      bottom: 3rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      color: rgba(255,255,255,0.4);
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      animation: fgFadeIn 1s 1.5s both;
    }
    .fg-scroll-line {
      width: 1px;
      height: 40px;
      background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.4));
      animation: fgScrollPulse 2s infinite;
    }

    /* SECTION STYLES */
    .fg-hero ~ section,
    .fg-faq, .fg-contact {
      padding: 7rem 0;
    }
    .fg-container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 2.5rem;
    }
    .fg-section-label {
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #C17F3A;
      margin-bottom: 1rem;
      display: block;
    }
    .fg-section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 3.5vw, 2.8rem);
      line-height: 1.2;
      color: #3d3532;
      margin: 0 0 1.5rem;
    }
    .fg-section-title em {
      font-style: italic;
      color: #C17F3A;
    }
    .fg-divider {
      width: 60px;
      height: 1px;
      background: #C17F3A;
      margin-bottom: 2rem;
    }
    .fg-text-center { text-align: center; }

    /* ABOUT */
    .fg-about {
      background: #fff;
      clip-path: polygon(0 2rem, 100% 0, 100% 100%, 0 100%);
      margin-top: -2rem;
      padding-top: 9rem;
    }
    .fg-about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: center;
    }
    .fg-about-img {
      position: relative;
    }
    .fg-about-img img {
      width: 100%;
      aspect-ratio: 4/5;
      object-fit: cover;
      object-position: center top;
      display: block;
    }
    .fg-about-img::before {
      content: '';
      position: absolute;
      top: -1.5rem; left: -1.5rem;
      right: 1.5rem; bottom: 1.5rem;
      border: 1px solid #ddd4c8;
      z-index: -1;
    }
    .fg-about-badge {
      position: absolute;
      bottom: -1.5rem; right: -1.5rem;
      background: #C17F3A;
      color: white;
      padding: 1.2rem 1.8rem;
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 0.95rem;
      line-height: 1.4;
      text-align: center;
      max-width: 160px;
    }
    .fg-about-text p {
      font-weight: 300;
      line-height: 1.9;
      color: #5a5a5a;
      margin: 0 0 1.5rem;
      font-size: 1.05rem;
    }
    .fg-about-signature {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1.5rem;
      color: #C17F3A;
      margin-top: 2rem;
    }

    /* CATEGORIES */
    .fg-categories {
      background: #FFFCFA;
      clip-path: polygon(0 2rem, 100% 0, 100% 100%, 0 100%);
      margin-top: -2rem;
      padding-top: 9rem;
    }
    .fg-categories-header {
      text-align: center;
      margin-bottom: 5rem;
    }
    .fg-categories-header .fg-divider { margin: 0 auto 2rem; }
    .fg-cat-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }
    .fg-cat-card {
      position: relative;
      overflow: hidden;
      cursor: default;
    }
    .fg-cat-card-inner {
      aspect-ratio: 4/5;
      background: #ECE4DB;
      position: relative;
      overflow: hidden;
      transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .fg-cat-card:hover .fg-cat-card-inner { transform: scale(1.02); }
    .fg-cat-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
    }
    .fg-cat-img--top { object-position: center top; }
    .fg-cat-number {
      position: absolute;
      top: 2rem; left: 2rem;
      font-family: 'Playfair Display', serif;
      font-size: 3.5rem;
      color: #C17F3A;
      opacity: 0.25;
      line-height: 1;
    }
    .fg-cat-content {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 2.5rem 2rem;
      background: linear-gradient(to top, rgba(30,22,20,0.97) 0%, rgba(30,22,20,0.6) 50%, rgba(30,22,20,0.15) 100%);
      color: white;
      transform: translateY(0);
      transition: transform 0.4s ease;
    }
    .fg-cat-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.7rem;
      font-style: italic;
      margin-bottom: 0.5rem;
      text-shadow: 0 2px 8px rgba(0,0,0,0.4);
    }
    .fg-cat-subtitle {
      font-size: 0.72rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #d4975a;
      margin-bottom: 1rem;
    }
    .fg-cat-desc {
      font-size: 0.88rem;
      line-height: 1.7;
      color: rgba(255,255,255,0.8);
      font-weight: 300;
      opacity: 0;
      max-height: 0;
      overflow: hidden;
      transition: opacity 0.4s ease, max-height 0.4s ease;
    }
    .fg-cat-card:hover .fg-cat-desc {
      opacity: 1;
      max-height: 200px;
    }
    .fg-cat-tip {
      margin-top: 1rem;
      padding: 0.8rem 1rem;
      border-left: 2px solid #C17F3A;
      font-size: 0.8rem;
      color: rgba(255,255,255,0.8);
      opacity: 0;
      transition: opacity 0.3s 0.2s ease;
    }
    .fg-cat-card:hover .fg-cat-tip { opacity: 1; }

    /* PACKAGES */
    .fg-packages {
      background: #3d3532;
      color: white;
      clip-path: polygon(0 2rem, 100% 0, 100% 100%, 0 100%);
      margin-top: -2rem;
      padding-top: 9rem;
    }
    .fg-packages .fg-section-title { color: white; }
    .fg-packages .fg-section-label { color: #d4975a; }
    .fg-packages-header {
      text-align: center;
      margin-bottom: 4rem;
    }
    .fg-pkg-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-bottom: 3rem;
    }
    .fg-pkg-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      padding: 2.5rem 2rem;
      position: relative;
      transition: all 0.3s ease;
      cursor: default;
    }
    .fg-pkg-card:hover {
      background: rgba(255,255,255,0.07);
      border-color: rgba(193,127,58,0.4);
      transform: translateY(-4px);
    }
    .fg-pkg-card.fg-featured {
      border-color: #C17F3A;
      background: rgba(193,127,58,0.08);
    }
    .fg-pkg-card.fg-featured::before {
      content: 'BELIEBT';
      position: absolute;
      top: -1px; right: 2rem;
      background: #C17F3A;
      color: white;
      font-size: 0.62rem;
      letter-spacing: 0.15em;
      padding: 0.3rem 0.8rem;
    }
    .fg-pkg-name {
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #d4975a;
      margin-bottom: 1rem;
    }
    .fg-pkg-price {
      font-family: 'Playfair Display', serif;
      font-size: 3rem;
      color: white;
      line-height: 1;
      margin-bottom: 0.3rem;
    }
    .fg-pkg-price span {
      font-size: 1.2rem;
      color: #d4975a;
    }
    .fg-pkg-divider {
      width: 30px;
      height: 1px;
      background: #C17F3A;
      margin: 1.5rem 0;
    }
    .fg-pkg-features {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
      margin: 0;
      padding: 0;
    }
    .fg-pkg-features li {
      font-size: 0.88rem;
      color: rgba(255,255,255,0.7);
      font-weight: 300;
      display: flex;
      gap: 0.8rem;
      align-items: flex-start;
      line-height: 1.5;
    }
    .fg-pkg-features li::before {
      content: '✓';
      color: #C17F3A;
      flex-shrink: 0;
      margin-top: 0.05rem;
    }
    .fg-pkg-feature-accent {
      color: #d4975a !important;
      font-style: italic;
    }
    .fg-extras-bar {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      padding: 2rem 2.5rem;
      display: flex;
      gap: 3rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .fg-extra-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex: 1;
      min-width: 200px;
    }
    .fg-extras-divider {
      width: 1px;
      align-self: stretch;
      background: rgba(255,255,255,0.08);
      flex-shrink: 0;
    }
    .fg-extra-label {
      font-size: 0.78rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #d4975a;
      margin-bottom: 0.2rem;
    }
    .fg-extra-desc {
      font-size: 0.83rem;
      color: rgba(255,255,255,0.55);
      font-weight: 300;
    }
    .fg-extra-price-tag {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      color: white;
      white-space: nowrap;
      margin-left: auto;
      padding-left: 1rem;
    }
    .fg-extra-price-tag--light { color: #d4975a; }

    /* TIPS */
    .fg-tips {
      background: #ECE4DB;
      clip-path: polygon(0 2rem, 100% 0, 100% 100%, 0 100%);
      margin-top: -2rem;
      padding-top: 9rem;
    }
    .fg-tips-header { margin-bottom: 4rem; }
    .fg-tips-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
    .fg-tip-card {
      background: #fff;
      padding: 2.5rem;
      border-bottom: 3px solid transparent;
      transition: border-color 0.3s ease;
    }
    .fg-tip-card:hover { border-color: #C17F3A; }
    .fg-tip-icon { font-size: 2rem; margin-bottom: 1rem; display: block; }
    .fg-tip-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem;
      margin-bottom: 0.8rem;
      color: #3d3532;
    }
    .fg-tip-text {
      font-size: 0.9rem;
      line-height: 1.8;
      color: #6a6a6a;
      font-weight: 300;
      margin: 0;
    }
    .fg-tip-highlight {
      margin-top: 0.8rem;
      font-size: 0.8rem;
      color: #C17F3A;
      letter-spacing: 0.05em;
      font-style: italic;
    }

    /* PROCESS */
    .fg-process {
      background: #fff;
      clip-path: polygon(0 2rem, 100% 0, 100% 100%, 0 100%);
      margin-top: -2rem;
      padding-top: 9rem;
    }
    .fg-process-header { text-align: center; margin-bottom: 4rem; }
    .fg-process-steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      position: relative;
    }
    .fg-process-steps::before {
      content: '';
      position: absolute;
      top: 2rem;
      left: 12.5%;
      right: 12.5%;
      height: 1px;
      background: #ddd4c8;
      z-index: 0;
    }
    .fg-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0 1.5rem;
      position: relative;
      z-index: 1;
    }
    .fg-step-num {
      width: 4rem;
      height: 4rem;
      border-radius: 50%;
      background: #FFFCFA;
      border: 1px solid #ddd4c8;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      color: #C17F3A;
      margin-bottom: 1.5rem;
      transition: all 0.3s ease;
    }
    .fg-step:hover .fg-step-num {
      background: #C17F3A;
      color: white;
      border-color: #C17F3A;
    }
    .fg-step-title {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      margin-bottom: 0.6rem;
      color: #3d3532;
    }
    .fg-step-text {
      font-size: 0.83rem;
      color: #888;
      line-height: 1.7;
      font-weight: 300;
      margin: 0;
    }

    /* REVIEWS */
    .fg-reviews {
      background: #FFFCFA;
      clip-path: polygon(0 2rem, 100% 0, 100% 100%, 0 100%);
      margin-top: -2rem;
      padding-top: 9rem;
    }
    .fg-reviews-header { text-align: center; margin-bottom: 4rem; }
    .fg-reviews-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .fg-review-card {
      background: #fff;
      padding: 3rem;
      position: relative;
      border-top: 1px solid #ddd4c8;
    }
    .fg-review-quote {
      font-family: 'Playfair Display', serif;
      font-size: 5rem;
      color: #C17F3A;
      opacity: 0.2;
      line-height: 0.5;
      margin-bottom: 1.5rem;
      display: block;
    }
    .fg-review-stars {
      color: #C17F3A;
      font-size: 0.9rem;
      letter-spacing: 0.1em;
      margin-bottom: 1.2rem;
    }
    .fg-review-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      line-height: 1.8;
      color: #5a5a5a;
      font-style: italic;
      margin: 0 0 1.5rem;
    }
    .fg-review-author {
      font-size: 0.78rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #917C71;
    }
    .fg-review-badge {
      position: absolute;
      top: 2rem; right: 2rem;
      background: #C17F3A;
      color: white;
      border-radius: 50%;
      width: 2.5rem; height: 2.5rem;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.05em;
    }

    /* FAQ */
    .fg-faq {
      background: #fff;
      clip-path: polygon(0 2rem, 100% 0, 100% 100%, 0 100%);
      margin-top: -2rem;
      padding-top: 9rem;
    }
    .fg-faq-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
    .fg-faq-left .fg-section-title { margin-bottom: 2rem; }
    .fg-faq-left p {
      font-weight: 300;
      line-height: 1.9;
      color: #6a6a6a;
      font-size: 1rem;
    }
    .fg-faq-items {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .fg-faq-item {
      border-bottom: 1px solid #ddd4c8;
      overflow: hidden;
    }
    .fg-faq-q {
      padding: 1.5rem 0;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.95rem;
      color: #3d3532;
      font-weight: 400;
      transition: color 0.2s;
      user-select: none;
    }
    .fg-faq-q:hover { color: #C17F3A; }
    .fg-faq-q::after {
      content: '+';
      font-size: 1.3rem;
      color: #C17F3A;
      transition: transform 0.3s ease;
      flex-shrink: 0;
      margin-left: 1rem;
    }
    .fg-faq-item.fg-open .fg-faq-q::after { transform: rotate(45deg); }
    .fg-faq-a {
      font-size: 0.88rem;
      line-height: 1.9;
      color: #6a6a6a;
      font-weight: 300;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease, padding 0.3s ease;
    }
    .fg-faq-item.fg-open .fg-faq-a {
      max-height: 400px;
      padding-bottom: 1.5rem;
    }

    /* CONTACT */
    .fg-contact {
      background: #3d3532;
      text-align: center;
      padding: 8rem 0;
      position: relative;
      overflow: hidden;
      clip-path: polygon(0 2rem, 100% 0, 100% 100%, 0 100%);
      margin-top: -2rem;
      padding-top: 10rem;
    }
    .fg-contact::before {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 600px; height: 600px;
      background: radial-gradient(ellipse, rgba(193,127,58,0.1) 0%, transparent 70%);
    }
    .fg-contact .fg-section-label { text-align: center; }
    .fg-contact .fg-section-title {
      color: white;
      text-align: center;
      font-size: clamp(2.5rem, 5vw, 4rem);
      margin-bottom: 1.5rem;
    }
    .fg-contact-sub {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1.3rem;
      color: rgba(255,255,255,0.5);
      margin-bottom: 3rem;
    }
    .fg-contact-links {
      display: flex;
      gap: 2rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 3rem;
    }
    .fg-contact-link {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 300;
      transition: color 0.2s;
    }
    .fg-contact-link:hover { color: #d4975a; }
    .fg-contact-link-icon {
      width: 2.2rem; height: 2.2rem;
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.9rem;
    }
    .fg-cta-btn {
      display: inline-block;
      padding: 1.2rem 3.5rem;
      background: #C17F3A;
      color: white;
      font-family: 'Jost', sans-serif;
      font-size: 0.8rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      text-decoration: none;
      transition: all 0.3s ease;
    }
    .fg-cta-btn:hover {
      background: #d4975a;
      transform: translateY(-2px);
    }
    .fg-contact-signature {
      margin-top: 4rem;
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1.8rem;
      color: rgba(255,255,255,0.3);
    }
    .fg-copyright {
      margin-top: 3rem;
      font-size: 0.72rem;
      color: rgba(255,255,255,0.2);
      letter-spacing: 0.08em;
    }

    /* BACK TO TOP */
    .fg-back-to-top {
      position: fixed;
      bottom: 2rem; right: 2rem;
      width: 3rem; height: 3rem;
      background: #C17F3A;
      color: white;
      border: none;
      border-radius: 50%;
      font-size: 1.1rem;
      cursor: pointer;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.3s, transform 0.3s, background 0.2s;
      z-index: 200;
      box-shadow: 0 4px 15px rgba(193,127,58,0.4);
    }
    .fg-back-to-top:hover { background: #d4975a; }
    .fg-back-to-top.fg-visible { opacity: 1; transform: translateY(0); }

    /* ANIMATIONS */
    @keyframes fgFadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fgFadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes fgScrollPulse {
      0%, 100% { transform: scaleY(1); opacity: 0.4; }
      50% { transform: scaleY(1.2); opacity: 0.8; }
    }

    body:has(.fg-hero) .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    body:has(.fg-hero) .reveal.is-visible,
    body:has(.fg-hero) .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      .fg-hero { grid-template-columns: 1fr; min-height: 100svh; position: relative; }
      .fg-hero-right { display: block; position: absolute; inset: 0; z-index: 0; }
      .fg-hero-right img { width: 100%; height: 100%; object-fit: cover; filter: saturate(0.7) brightness(0.45); }
      .fg-hero-right::after { display: none; }
      .fg-hero-left { padding: 7rem 2.5rem 5rem; position: relative; z-index: 1; background: transparent; }
      .fg-about-grid, .fg-faq-grid { grid-template-columns: 1fr; gap: 3rem; }
      .fg-cat-grid { grid-template-columns: 1fr; gap: 1rem; }
      .fg-cat-content { transform: translateY(0); }
      .fg-cat-desc { opacity: 1; max-height: 200px; }
      .fg-cat-tip { opacity: 1; }
      .fg-pkg-grid { grid-template-columns: 1fr; }
      .fg-tips-grid { grid-template-columns: 1fr; }
      .fg-process-steps { grid-template-columns: 1fr 1fr; gap: 2rem; }
      .fg-process-steps::before { display: none; }
      .fg-reviews-grid { grid-template-columns: 1fr; }
      .fg-nav { padding: 1rem 1.5rem; }
      .fg-nav-links { display: none; }
      .fg-extras-bar { flex-direction: column; gap: 1.5rem; }
      .fg-extras-divider { width: 100%; height: 1px; }
    }
    @media (max-width: 500px) {
      .fg-hero ~ section,
      .fg-faq, .fg-contact { padding: 5rem 0; }
      .fg-container { padding: 0 1.5rem; }
      .fg-process-steps { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    // FAQ accordion
    document.querySelectorAll('.fg-faq-q').forEach((q) => {
      q.addEventListener('click', () => {
        const item = q.parentElement;
        if (!item) return;
        const isOpen = item.classList.contains('fg-open');
        document.querySelectorAll('.fg-faq-item').forEach((i) => i.classList.remove('fg-open'));
        if (!isOpen) item.classList.add('fg-open');
      });
    });

    // Back to top
    const fgBtn = document.getElementById('fgBackToTop');
    if (fgBtn) {
      window.addEventListener('scroll', () => {
        fgBtn.classList.toggle('fg-visible', window.scrollY > 400);
      }, { passive: true });
      fgBtn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    // Active nav link on scroll
    if ('IntersectionObserver' in window) {
      const sections = document.querySelectorAll('.fg-hero ~ section[id]');
      const navLinks = document.querySelectorAll('.fg-nav-links a');
      const navObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            navLinks.forEach((a) => a.classList.remove('active'));
            const active = document.querySelector(`.fg-nav-links a[href="#${entry.target.id}"]`);
            if (active) active.classList.add('active');
          }
        });
      }, { threshold: 0.4 });
      sections.forEach((s) => navObserver.observe(s));
    }
  </script>
</BaseLayout>
